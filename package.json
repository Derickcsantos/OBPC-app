{
  "name": "ObpcApp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "start:tunnel": "expo start -c --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "apk": "npx eas-cli build --platform android --profile apk",
    "apk:local": "cd android && gradlew.bat assembleRelease",
    "build": "expo export",
    "build:web": "expo export --platform web",
    "build:android": "expo export --platform android",
    "build:ios": "expo export --platform ios",
    "ipa": "npx eas-cli build --platform ios --profile production",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.7.2",
    "expo": "~55.0.26",
    "expo-network": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@types/react": "~19.2.10",
    "react-native-svg-transformer": "^1.5.3",
    "resolve-from": "^5.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
