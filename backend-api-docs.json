{
  "application": {
    "name": "Church Mobile API",
    "description": "API para aplicativo mobile de igreja com CRUDs em Supabase e consulta à API externa da Bíblia.",
    "basePath": "/api",
    "healthPath": "/health",
    "stack": [
      "Node.js",
      "TypeScript",
      "Fastify",
      "Zod",
      "Supabase"
    ],
    "features": [
      "CRUD de ministérios, usuários, eventos, notícias, louvores, mensagens e orações",
      "Consulta de versões, livros, capítulos, versículos e busca exata na Bíblia",
      "Validação de entrada com Zod",
      "Tratamento padronizado de erros"
    ]
  },
  "common": {
    "idParam": {
      "name": "id",
      "in": "path",
      "required": true,
      "type": "string",
      "format": "uuid"
    },
    "successResponseShapes": {
      "list": {
        "statusCode": 200,
        "body": {
          "data": ["record"]
        }
      },
      "getById": {
        "statusCode": 200,
        "body": {
          "data": "record"
        }
      },
      "create": {
        "statusCode": 201,
        "body": {
          "message": "string",
          "data": "record"
        }
      },
      "update": {
        "statusCode": 200,
        "body": {
          "message": "string",
          "data": "record"
        }
      },
      "remove": {
        "statusCode": 200,
        "body": {
          "message": "string",
          "data": "record"
        }
      }
    },
    "errorResponses": [
      {
        "statusCode": 400,
        "body": {
          "message": "Erro de validação",
          "details": "validation details"
        }
      },
      {
        "statusCode": 404,
        "body": {
          "message": "resource não encontrado",
          "details": null
        }
      },
      {
        "statusCode": 500,
        "body": {
          "message": "Erro interno do servidor"
        }
      }
    ]
  },
